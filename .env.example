# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your actual keys
# For Railway: set these in the Railway Dashboard → Variables tab
# ─────────────────────────────────────────────────

# Primary LLM provider (Google Gemini) — REQUIRED
GEMINI_API_KEY=your-gemini-api-key-here

# Fallback LLM provider (Groq) — optional but recommended
GROQ_API_KEY=your-groq-api-key-here

# Optional: override default model names
# GEMINI_MODEL=gemini-1.5-flash
# GROQ_MODEL=llama-3.1-8b-instant

# ── Railway sets PORT automatically, do NOT override ──
# PORT is injected by Railway at runtime
